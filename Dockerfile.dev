# Spirit Animals Go - Development Dockerfile
# No GPU required, uses mock KataGo

FROM rust:latest

# Install system dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy project files
COPY Cargo.toml ./
# Note: Not copying Cargo.lock - let cargo generate compatible versions
COPY src/ ./src/
COPY configs/ ./configs/
COPY configs-dev/ ./configs-dev/
COPY frontend/ ./frontend/
COPY scripts/ ./scripts/

# Build Rust application (release mode)
RUN cargo build --release

# Expose port
EXPOSE 3000

# Environment variables
ENV KATAGO_BINARY=/app/scripts/mock_katago.sh
ENV ANIMAL_GO_CONFIG_DIR=/app/configs-dev
ENV RUST_LOG=debug

# Run the application
CMD ["./target/release/animal_go"]
