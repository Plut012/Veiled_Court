# Spirit Animals Go - Environment Variables

# KataGo Configuration
KATAGO_BINARY=/usr/local/bin/katago
KATAGO_NETS_PATH=/app/nets

# Application Configuration
ANIMAL_GO_CONFIG_DIR=/app/configs
RUST_LOG=info
ENV=production

# Server Configuration
HOST=0.0.0.0
PORT=3000

# Development Mode
# Set KATAGO_BINARY=/app/scripts/mock_katago.sh for laptop dev
# Set ANIMAL_GO_CONFIG_DIR=/app/configs-dev for reduced visit counts
